# =============================================================================
# SpeedBack Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase (required) ---
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — only needed for seed scripts and admin operations
# NEVER expose this in the browser. Get it from Settings > API > service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App URL (required) ---
# The public URL where your app is hosted
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PostHog Analytics (optional) ---
# Sign up at https://posthog.com (free tier available)
# Leave blank to disable analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Admin Access (optional) ---
# Email address of the admin user who can access /admin analytics
# Must match a Supabase Auth user's email
# NEXT_PUBLIC_OWNER_EMAIL=you@example.com

# --- Community Links (optional) ---
# GitHub Issues URL — shown as "Request a feature / Report a bug" in the dashboard
# NEXT_PUBLIC_GITHUB_ISSUES_URL=https://github.com/SpeedbackHQ/speedback/issues

# Donation URL — shown as "Support SpeedBack" across the app
# Accepts any URL: Buy Me a Coffee, GitHub Sponsors, Open Collective, etc.
# NEXT_PUBLIC_DONATION_URL=https://buymeacoffee.com/your-page
